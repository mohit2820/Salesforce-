public class ContactTriggerHandler {
    
    public static void updateAccountScore(Set<Id> accIds){
        
        Map<Id,List<Double>> accScoreMap = new Map<Id,List<Double>>();
        for(AggregateResult ar : [SELECT AccountId , SUM(Score1_c__c) sc1 , SUM(Score2_c__c) sc2 FROM Contact WHERE AccountId IN: accIds GROUP BY AccountId]){
            
            Id accId = (Id) ar.get('AccountId');
            Double score1 = (Double) ar.get('sc1');
            Double score2 = (Double) ar.get('sc2');
            
            if(score1==0 && score2==0) continue; 
            
            if(!accScoreMap.containsKey(accId)){
                List<Double> scoreList = new List<Double>();
                scoreList.add(score1);
                scoreList.add(score2);
                accScoreMap.put(accId , scoreList);
            }
            
            else {
                List<Double> updateScore = accScoreMap.get(accId);
                updateScore[0] = updateScore.get(0) + score1;
                updateScore[1] = updateScore.get(1) + score2;
                accScoreMap.put(accId, updateScore);
            }
        }
        
        List<Account> accListToUpdate = new List<Account>();
        for(Id accId : accIds){
            
            if(accScoreMap.containsKey(accId)){
                List<Double> getScore = accScoreMap.get(accId);
                accListToUpdate.add(new Account(id=accId , Account_Score1_c__c=getScore.get(0) , Account_Score2_c__c = getScore.get(1)));
            }
            
            else{
                accListToUpdate.add(new Account(id=accId , Account_Score1_c__c=0 , Account_Score2_c__c = 0));
            }
        }
        
        if(!accListToUpdate.isEmpty()) update accListToUpdate;
        
    }
}
